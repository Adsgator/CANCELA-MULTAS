---
import { Image } from "astro:assets";
import avatarLinks from "../assets/avatar_links.webp";
import bannerHero from "../assets/banner_links.webp";

export const prerender = true;

const GTM_ID = "GTM-M7S2PDFR";

const waNumber = "5548996729999";
const waMessage = encodeURIComponent("Olá! Vim do Google e gostaria de mais informações");

const perfil = {
  nome: "Cancela Multas",
  cargo: "Especialistas em Recursos de Multas · Brasil",
};

/* const redesSociais = [
  {
    nome: "Instagram",
    href: "https://www.instagram.com/cancela.multas",
    ariaLabel: "Instagram da Cancela Multas",
    tracking: "click-instagram-links",
  },
  {
    nome: "Facebook",
    href: "https://www.facebook.com/cancela.multas",
    ariaLabel: "Facebook da Cancela Multas",
    tracking: "click-facebook-links",
  },
]; */

const links = [
  {
    id: "btn-links-site",
    label: "Acessar o site",
    href: "https://cancelamulta.com.br",
    tracking: "click-site-links",
    variant: "primary",
    newTab: false,
    iconSVG:
      '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>',
  },
  {
    id: "btn-links-wa",
    label: "Falar no WhatsApp",
    href: `https://wa.me/${waNumber}?text=${waMessage}`,
    tracking: "click-whatsapp-links",
    variant: "wa",
    newTab: true,
    iconSVG:
      '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>',
  },
  {
    id: "btn-links-avaliacoes",
    label: "Deixe sua avaliação",
    href: "https://g.page/r/Cba9IWmi001eEAE/review",
    tracking: "click-avaliacoes-links",
    variant: "ghost",
    newTab: true,
    iconSVG:
      '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>',
  },
];

const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />

    <!-- GTM Head -->
    <script is:inline define:vars={{ GTM_ID }}>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", GTM_ID);
    </script>

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, follow" />
    <meta name="theme-color" content="#144e74" />
    <title>Cancela Multas | Links</title>
    <meta
      name="description"
      content="Especialistas em recursos de multas de trânsito e defesa da CNH. Atendimento 100% online."
    />
    <link rel="canonical" href="https://cancelamulta.com.br/links" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content="Cancela Multas | Links" />
    <meta
      property="og:description"
      content="Especialistas em recursos de multas de trânsito e defesa da CNH. Atendimento 100% online."
    />
    <meta property="og:type" content="website" />

    <!-- Consent Mode v2 -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("consent", "default", {
        ad_storage: "denied",
        analytics_storage: "denied",
        wait_for_update: 500,
      });
    </script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
      rel="stylesheet"
    />

    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html,
      body {
        height: 100%;
      }
      body {
        font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
        font-weight: 400;
        background-color: #e8eef3;
        color: #333333;
        -webkit-font-smoothing: antialiased;
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      /* ── Layout geral ──────────────────────────── */
      .links-page {
        min-height: 100vh;
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      /* ── Hero Banner ───────────────────────────── */
      .hero-banner {
        position: relative;
        width: 100%;
        max-width: 430px;
        height: 220px;
        overflow: hidden;
        flex-shrink: 0;
      }

      .hero-banner__img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 30%;
        display: block;
      }

      .hero-banner__overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
          to bottom,
          rgba(20, 78, 116, 0.25) 0%,
          rgba(13, 31, 46, 0.55) 100%
        );
      }

      /* ── Card Principal ────────────────────────── */
      .profile-card {
        width: 100%;
        max-width: 430px;
        background-color: #f5f8fb;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 0 20px 48px;
        flex: 1;
      }

      /* ── Avatar ────────────────────────────────── */
      .avatar-wrapper {
        margin-top: -48px;
        z-index: 10;
        position: relative;
      }

      .avatar {
        width: 96px;
        height: 96px;
        border-radius: 50%;
        object-fit: cover;
        object-position: center top;
        border: 4px solid #f5f8fb;
        box-shadow: 0 4px 20px rgba(13, 31, 46, 0.22);
        display: block;
        background-color: #d0dde8;
      }

      /* ── Perfil Info ───────────────────────────── */
      .profile-info {
        margin-top: 14px;
        text-align: center;
        margin-bottom: 8px;
      }

      .profile-name {
        font-family: "Inter", system-ui, sans-serif;
        font-size: 1.6rem;
        font-weight: 800;
        color: #144e74;
        letter-spacing: -0.02em;
        line-height: 1.1;
      }

      .profile-role {
        font-family: "Inter", system-ui, sans-serif;
        font-size: 11px;
        font-weight: 600;
        color: #595959;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        margin-top: 5px;
      }

      /* ── Redes Sociais (oculto — descomentar quando o cliente tiver perfis) ── */
      /*
    .social-icons {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 18px;
      margin-top: 20px;
      margin-bottom: 28px;
    }

    .social-icon-link {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border: 1px solid #c4d4e0;
      border-radius: 6px;
      color: #595959;
      text-decoration: none;
      transition: border-color 0.18s ease, color 0.18s ease, transform 0.15s ease;
    }

    .social-icon-link:hover {
      border-color: #144e74;
      color: #144e74;
      transform: translateY(-1px);
    }

    .social-icon-link:active { transform: scale(0.95); }

    .social-icon-link:focus-visible {
      outline: 2px solid #144e74;
      outline-offset: 2px;
    }
    */

      /* ── Lista de Links ─────────────────────────── */
      .links-list {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 12px;
      }

      /* ── Link Button ────────────────────────────── */
      .link-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        width: 100%;
        padding: 16px 24px;
        font-family: "Inter", system-ui, sans-serif;
        font-size: 15px;
        font-weight: 600;
        letter-spacing: 0.01em;
        text-decoration: none;
        border-radius: 8px;
        border: none;
        transition:
          background-color 0.18s ease,
          transform 0.15s ease,
          box-shadow 0.18s ease,
          border-color 0.18s ease,
          color 0.18s ease;
        cursor: pointer;
      }

      .link-btn:hover {
        transform: translateY(-1px);
      }
      .link-btn:active {
        transform: translateY(0);
      }

      .link-btn:focus-visible {
        outline: 2px solid #144e74;
        outline-offset: 2px;
      }

      .link-btn.primary {
        background-color: #144e74;
        color: #ffffff;
        box-shadow: 0 2px 14px rgba(20, 78, 116, 0.3);
      }

      .link-btn.primary:hover {
        background-color: #0f3e5e;
        box-shadow: 0 4px 20px rgba(20, 78, 116, 0.42);
      }

      .link-btn.wa {
        background-color: #25d366;
        color: #ffffff;
        box-shadow: 0 2px 14px rgba(37, 211, 102, 0.28);
      }

      .link-btn.wa:hover {
        background-color: #1da851;
        box-shadow: 0 4px 20px rgba(37, 211, 102, 0.38);
      }

      .link-btn.ghost {
        background-color: #ffffff;
        color: #333333;
        border: 1px solid #c4d4e0;
        box-shadow: 0 1px 4px rgba(13, 31, 46, 0.07);
      }

      .link-btn.ghost:hover {
        border-color: #144e74;
        color: #144e74;
        box-shadow: 0 4px 14px rgba(13, 31, 46, 0.1);
      }

      /* ── Rodapé ─────────────────────────────────── */
      .page-footer {
        margin-top: 40px;
        font-family: "Inter", system-ui, sans-serif;
        font-size: 11px;
        color: rgba(51, 51, 51, 0.4);
        text-align: center;
        line-height: 1.6;
      }

      /* ── Animações ──────────────────────────────── */
      .link-item {
        opacity: 0;
        transform: translateY(20px);
      }

      @keyframes fadeUp {
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .link-item {
          opacity: 1;
          transform: none;
          animation: none !important;
        }
      }
    </style>
  </head>
  <body>
    <!-- GTM noscript -->
    <noscript>
      <iframe
        src={`https://www.googletagmanager.com/ns.html?id=${GTM_ID}`}
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe>
    </noscript>

    <main class="links-page">
      <!-- ── HERO BANNER ───────────────────────────── -->
      <div class="hero-banner" role="img" aria-label="Banner da Cancela Multas">
        <Image
          src={bannerHero}
          alt="Cancela Multas — Especialistas em recursos de multas"
          class="hero-banner__img"
          width={860}
          height={480}
          fetchpriority="high"
          decoding="async"
        />
        <div class="hero-banner__overlay" aria-hidden="true"></div>
      </div>

      <!-- ── CARD PRINCIPAL ────────────────────────── -->
      <div class="profile-card">
        <!-- Avatar na divisória -->
        <div
          class="avatar-wrapper link-item"
          style="animation: fadeUp 0.5s 0s ease both"
        >
          <Image
            src={avatarLinks}
            alt="Cancela Multas"
            class="avatar"
            width={200}
            height={200}
            loading="eager"
            decoding="async"
          />
        </div>

        <!-- Nome + Cargo -->
        <div
          class="profile-info link-item"
          style="animation: fadeUp 0.5s 0.07s ease both"
        >
          <h1 class="profile-name">{perfil.nome}</h1>
          <p class="profile-role">{perfil.cargo}</p>
        </div>

        <!-- Redes Sociais (oculto — descomentar quando o cliente tiver perfis) -->
        <!--
      <nav class="social-icons link-item" style="animation: fadeUp 0.5s 0.14s ease both" aria-label="Redes sociais">
        {redesSociais.map((rede) => (
          <a
            href={rede.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={rede.ariaLabel}
            data-tracking={rede.tracking}
            data-section="links"
            class="social-icon-link"
          >
            {rede.nome === 'Instagram' && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M7.8,2H16.2C19.4,2 22,4.6 22,7.8V16.2C22,19.4 19.4,22 16.2,22H7.8C4.6,22 2,19.4 2,16.2V7.8C2,4.6 4.6,2 7.8,2M7.6,4A3.6,3.6 0 0,0 4,7.6V16.4A3.6,3.6 0 0,0 7.6,20H16.4A3.6,3.6 0 0,0 20,16.4V7.6A3.6,3.6 0 0,0 16.4,4H7.6M17.2,6A1.2,1.2 0 0,1 18.4,7.2A1.2,1.2 0 0,1 17.2,8.4A1.2,1.2 0 0,1 16,7.2A1.2,1.2 0 0,1 17.2,6M12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9Z"/>
              </svg>
            )}
            {rede.nome === 'Facebook' && (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
            )}
          </a>
        ))}
      </nav>
      -->

        <!-- Links -->
        <div class="links-list" role="list">
          {
            links.map((link, i) => (
              <div
                role="listitem"
                class="link-item"
                style={`animation: fadeUp 0.5s ${0.2 + i * 0.08}s ease both`}
              >
                <a
                  href={link.href}
                  id={link.id}
                  data-tracking={link.tracking}
                  data-section="links"
                  class={`link-btn ${link.variant}`}
                  {...(link.newTab
                    ? { target: "_blank", rel: "noopener noreferrer" }
                    : {})}
                >
                  <span
                    class="link-btn-icon"
                    aria-hidden="true"
                    set:html={link.iconSVG}
                  />
                  <span>{link.label}</span>
                </a>
              </div>
            ))
          }
        </div>

        <!-- Rodapé -->
        <footer
          class="page-footer link-item"
          style={`animation: fadeUp 0.5s ${0.2 + links.length * 0.08}s ease both`}
        >
          <p>© {currentYear} Cancela Multas · Paulo Alexandre Souza Pires</p>
        </footer>
      </div>
    </main>

    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: "view_links", page_type: "links_page" });

      document.addEventListener("click", function (e) {
        var el = e.target.closest("[data-tracking]");
        if (!el) return;
        var action = el.getAttribute("data-tracking");
        var section = el.getAttribute("data-section");
        window.dataLayer.push({
          event: "link_click",
          click_action: action,
          click_section: section,
        });
        if (action && action.includes("whatsapp")) {
          window.dataLayer.push({
            event: "contato_wpp",
            click_action: action,
            click_section: section,
          });
        }
      });
    </script>
  </body>
</html>
